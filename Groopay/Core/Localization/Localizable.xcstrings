            "value": "Abonelik dönem sonunda otomatik yenilenir. İptal edilmezse ücret tahsil edilir. Hesap ayarlarından yönetebilirsiniz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The subscription renews automatically at the end of each period unless canceled. You can manage it in account settings."
